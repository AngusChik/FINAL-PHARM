# Copy this file to ".env" and fill in real values. ".env" is gitignored.

# --- Core ---
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-real-secret-key

# Set to "true" ONLY on a developer machine. Leave false/unset in production.
DJANGO_DEBUG=false

# --- HTTPS hardening ---
# Set to 1 ONLY when the Caddy HTTPS proxy is running in front of waitress.
# (See DEPLOYMENT_HTTPS.md.) Leave unset for plain-HTTP LAN mode.
# DJANGO_SECURE=1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://192.168.0.15,https://localhost

# --- Database ---
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
